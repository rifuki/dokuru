{
  "installCommand": "bun install --frozen-lockfile",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/install",
      "destination": "https://github.com/rifuki/dokuru/releases/download/latest/install.sh",
      "permanent": false
    },
    {
      "source": "/install.sh",
      "destination": "https://github.com/rifuki/dokuru/releases/download/latest/install.sh",
      "permanent": false
    },
    {
      "source": "/deploy",
      "destination": "https://github.com/rifuki/dokuru/releases/download/latest-deploy/install.sh",
      "permanent": false
    },
    {
      "source": "/deploy.sh",
      "destination": "https://github.com/rifuki/dokuru/releases/download/latest-deploy/install.sh",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
