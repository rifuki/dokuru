PORT=9393
RUST_ENV=development
RUST_LOG=DEBUG
CORS_ALLOWED_ORIGINS=http://localhost:4321
MAX_SESSIONS=2

# Terminal Sandbox Configuration
SANDBOX_IMAGE_ARCH=ghcr.io/rifuki/rifuki-sandbox:archlinux
SANDBOX_IMAGE_ALPINE=ghcr.io/rifuki/rifuki-sandbox:alpine
SANDBOX_IMAGE_DEBIAN=ghcr.io/rifuki/rifuki-sandbox:debian
TERMINAL_MEMORY=512m
TERMINAL_CPUS=0.5
TERMINAL_PIDS_LIMIT=64
TERMINAL_TMPFS_SIZE=64m
# TERMINAL_STORAGE_SIZE=1G # Optional (Requires XFS/pquota)

# Last.fm API Configuration
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_SHARED_SECRET=your_lastfm_shared_secret_here
LASTFM_USERNAME=your_lastfm_username_here
