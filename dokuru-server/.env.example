# Layered configuration precedence (highest wins):
#   environment variables / .env
#   config/secrets.toml
#   config/local.toml
#   config/defaults.toml
#
# Best practice:
# - Keep structured non-secret config in TOML files
# - Keep secrets and deployment-specific values in env
# - Use .env mainly for local development and container injection

# App / runtime overrides (optional; otherwise comes from defaults.toml)
RUST_ENV=development          # development | production
RUST_LOG=info                # overrides logging.default_level in TOML
PORT=9393                    # overrides server.port in TOML
CORS_ALLOWED_ORIGINS=http://localhost:5173  # overrides server.cors_allowed_origins

# Bootstrap Configuration (first-time setup)
# Set to false after initial admin is created
BOOTSTRAP_ENABLED=true

# Initial Admin Credentials (only used if no admin exists)
# IMPORTANT: Change these in production!
BOOTSTRAP_ADMIN_EMAIL=admin@dokuru.dev
BOOTSTRAP_ADMIN_PASSWORD=admin123        # Change this!
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_NAME=Administrator

# Database / infra (env is still a good fit here, especially in Docker)
DATABASE_URL=postgres://dokuru:secret@localhost:5432/dokuru_db
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1

# Redis (Optional — leave empty or comment out to disable)
REDIS_URL=redis://localhost:6379
# 
# Redis is used for:
# - Session blacklisting (logout/revoke token invalidation)
# - User profile caching
# - Distributed rate limiting
# 
# If not configured, these features will be disabled gracefully.

# JWT / auth secrets
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY_SECS=3600     # 1 hour
JWT_REFRESH_EXPIRY_SECS=604800  # 7 days

# Cookie overrides (optional; otherwise comes from TOML)
# COOKIE_SAMESITE=strict        # strict | lax | none. Default: strict (prod), lax (dev)
# COOKIE_SECURE=true            # true | false. Default: true (prod), false (dev)
# COOKIE_HTTPONLY=true          # true | false. Default: true
# 
# Scenarios:
# - Cross-port dev (5173->8080): lax (default dev)
# - Cross-subdomain: none + secure=true
# - Same origin: strict (most secure)

# Upload overrides (optional; otherwise comes from TOML)
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:9393/media
MAX_AVATAR_SIZE=2097152         # 2 MB in bytes
#
# IMPORTANT: Change UPLOAD_BASE_URL for production!
# 
# If FE (Vercel) and BE (VPS) are separate:
#   UPLOAD_BASE_URL=https://api.yourdomain.com/media
#
# If using S3/R2/MinIO:
#   UPLOAD_BASE_URL=https://cdn.yourdomain.com

# Email / notification secrets
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
#
# Email is used for:
# - Email verification after registration
# - Password reset requests
# - Account notifications
#
# Frontend reset URL is resolved from request Origin first,
# then CORS/server config as fallback.

# Practical guidance:
# - Put baseline app behavior in config/defaults.toml
# - Put safe per-host overrides in config/local.toml
# - Put file-based secrets in config/secrets.toml
# - Use .env when Docker/Compose or your deploy platform injects values
#
# See also:
# - config/defaults.toml
# - config/local.toml.example
# - config/secrets.toml.example
