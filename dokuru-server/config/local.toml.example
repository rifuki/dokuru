# Writable override layer for local or admin-edited config.
# This file is intended to be safe to edit and safe to commit only if it contains no secrets.
# It overrides defaults.toml, but can still be overridden by environment variables and .env.

[app]
rust_env = "development"
rust_log = "debug"

[server]
# Example: tighten CORS for a specific deployed frontend
cors_allowed_origins = ["https://app.dokuru.rifuki.dev"]

[bootstrap]
# Example: disable one-time bootstrap user creation after initial setup
enabled = false

[logging]
# Lower runtime noise by default in production-like local runs
default_level = "info"

[upload]
# Override public upload base URL without touching defaults.toml
base_url = "https://api.dokuru.rifuki.dev/media"

[cookie]
# Example cross-subdomain cookie policy
same_site = "none"
secure = true
